{
  "name": "theo",
  "version": "0.0.1",
  "private": true,
  "description": "Full-stack monorepo template: NestJS 11 API, Vite React SPA, Next.js 16 marketing site, Expo mobile app, and shared Better Auth, Mongoose database, and Turborepo.",
  "keywords": [
    "monorepo",
    "nestjs",
    "vite",
    "react",
    "nextjs",
    "expo",
    "react-native",
    "better-auth",
    "mongodb",
    "turborepo",
    "typescript",
    "template"
  ],
  "author": "Eaysin <https://github.com/imeaysin>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imeaysin/theo.git"
  },
  "bugs": {
    "url": "https://github.com/imeaysin/theo/issues"
  },
  "homepage": "https://github.com/imeaysin/theo#readme",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:web": "turbo dev --filter=web",
    "dev:marketing": "turbo dev --filter=marketing",
    "dev:mobile": "turbo dev --filter=mobile",
    "db:up": "bash scripts/db-up.sh",
    "db:down": "docker compose down",
    "setup": "cp -n .env.example .env && pnpm install && pnpm db:up",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e --filter=api",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,yml,yaml}": "prettier --write"
  }
}
