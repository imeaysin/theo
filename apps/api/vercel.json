{
  "version": 2,
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    }
  ],
  "env": {
    "NODE_OPTIONS": "--experimental-require-module"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--experimental-require-module"
    }
  }
}
