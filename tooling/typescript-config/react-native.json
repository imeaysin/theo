{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "module": "preserve",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "customConditions": ["react-native"],
    "jsx": "react-native",
    "allowJs": true,
    "noEmit": true
  }
}
