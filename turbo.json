{
  "$schema": "https://v2-10-3.turborepo.dev/schema.json",
  "ui": "tui",
  "concurrency": "15",
  "globalDependencies": [".npmrc", "pnpm-workspace.yaml", "tsconfig.json"],
  "globalEnv": [
    "MONGODB_URI",
    "BETTER_AUTH_SECRET",
    "ADMIN_USER_IDS",
    "BETTER_AUTH_URL",
    "RESEND_API_KEY",
    "CLIENT_URL",
    "GITHUB_REPO_URL",
    "MARKETING_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_AUTH_URL",
    "NEXT_PUBLIC_APP_NAME",
    "VITE_API_URL",
    "VITE_AUTH_URL",
    "VITE_APP_NAME",
    "VITE_MARKETING_URL",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_AUTH_URL",
    "EXPO_PUBLIC_APP_NAME",
    "APP_NAME",
    "PORT",
    "ALLOWED_ORIGINS",
    "AUTH_JWT_EXPIRATION",
    "AUTH_TOTP_ISSUER",
    "EMAIL_FROM",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "APPLE_CLIENT_ID",
    "APPLE_TEAM_ID",
    "APPLE_KEY_ID",
    "APPLE_PRIVATE_KEY",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "DISCORD_CLIENT_ID",
    "DISCORD_CLIENT_SECRET",
    "NODE_ENV",
    "LOG_LEVEL",
    "LOG_PRETTY",
    "CI",
    "JEST_WORKER_ID",
    "NEXT_PHASE",
    "SKIP_ENV_VALIDATION",
    "DEV",
    "STORAGE_PROVIDER",
    "STORAGE_LOCAL_PATH",
    "STORAGE_LOCAL_URL",
    "STORAGE_S3_BUCKET",
    "STORAGE_S3_REGION",
    "STORAGE_S3_ENDPOINT",
    "STORAGE_S3_ACCESS_KEY_ID",
    "STORAGE_S3_SECRET_ACCESS_KEY",
    "STORAGE_S3_BASE_URL",
    "RATE_LIMIT_ENABLED",
    "RATE_LIMIT_WINDOW_MS",
    "RATE_LIMIT_MAX",
    "JOBS_PROVIDER",
    "REDIS_URL",
    "JOBS_QUEUE_NAME",
    "EXPO_OS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
