{
  "name": "@workspace/permission-manager",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/integrations/react/index.d.ts",
      "import": "./dist/integrations/react/index.js",
      "require": "./dist/integrations/react/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/integrations/nestjs/index.d.ts",
      "import": "./dist/integrations/nestjs/index.js",
      "require": "./dist/integrations/nestjs/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {},
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.17.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
