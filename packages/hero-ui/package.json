{
  "name": "@workspace/hero-ui",
  "version": "1.0.0",
  "description": "HeroUI v3 React components wrapper for the monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "heroui",
    "react",
    "components",
    "ui"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "dependencies": {
    "@better-auth-ui/core": "^1.6.15",
    "@better-auth-ui/heroui": "^1.6.15",
    "@better-auth-ui/react": "^1.6.15",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/index.css",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./better-auth-ui": "./src/better-auth-ui/index.tsx"
  },
  "files": [
    "dist",
    "src/styles",
    "src/lib",
    "src/hooks"
  ]
}
