{
  "name": "@workspace/config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./database": {
      "types": "./dist/server/database.d.ts",
      "import": "./dist/server/database.js",
      "require": "./dist/server/database.cjs"
    },
    "./email": {
      "types": "./dist/server/email.d.ts",
      "import": "./dist/server/email.js",
      "require": "./dist/server/email.cjs"
    },
    "./storage": {
      "types": "./dist/server/storage.d.ts",
      "import": "./dist/server/storage.js",
      "require": "./dist/server/storage.cjs"
    },
    "./jobs": {
      "types": "./dist/server/jobs.d.ts",
      "import": "./dist/server/jobs.js",
      "require": "./dist/server/jobs.cjs"
    },
    "./push": {
      "types": "./dist/server/push.d.ts",
      "import": "./dist/server/push.js",
      "require": "./dist/server/push.cjs"
    },
    "./realtime": {
      "types": "./dist/server/realtime.d.ts",
      "import": "./dist/server/realtime.js",
      "require": "./dist/server/realtime.cjs"
    },
    "./cache": {
      "types": "./dist/server/cache.d.ts",
      "import": "./dist/server/cache.js",
      "require": "./dist/server/cache.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
