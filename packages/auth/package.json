{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Better Auth + CASL shared auth package for theo",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./access": {
      "types": "./dist/access/index.d.ts",
      "import": "./dist/access/index.js",
      "require": "./dist/access/index.cjs"
    },
    "./ability": {
      "types": "./dist/ability/index.d.ts",
      "import": "./dist/ability/index.js",
      "require": "./dist/ability/index.cjs"
    },
    "./ability/react": {
      "types": "./dist/ability/react.d.ts",
      "import": "./dist/ability/react.js",
      "require": "./dist/ability/react.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/client/web.d.ts",
      "import": "./dist/client/web.js",
      "require": "./dist/client/web.cjs"
    },
    "./client/web": {
      "types": "./dist/client/web.d.ts",
      "import": "./dist/client/web.js",
      "require": "./dist/client/web.cjs"
    },
    "./client/native": {
      "types": "./dist/client/native.d.ts",
      "import": "./dist/client/native.js",
      "require": "./dist/client/native.cjs"
    },
    "./mobile": {
      "types": "./dist/client/native.d.ts",
      "import": "./dist/client/native.js",
      "require": "./dist/client/native.cjs"
    },
    "./nestjs": {
      "types": "./dist/server/nest/index.d.ts",
      "import": "./dist/server/nest/index.js",
      "require": "./dist/server/nest/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@better-auth/expo": "catalog:",
    "@better-auth/redis-storage": "catalog:",
    "@casl/ability": "^7.0.1",
    "@casl/react": "^7.0.1",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/redis": "workspace:*",
    "better-auth": "catalog:",
    "mongodb": "^7.2.0",
    "nest-casl": "^1.9.15",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
