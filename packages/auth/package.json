{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/auth.cjs",
  "module": "./dist/auth.js",
  "types": "./dist/auth.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/auth.d.ts",
        "default": "./dist/auth.js"
      },
      "require": {
        "types": "./dist/auth.d.cts",
        "default": "./dist/auth.cjs"
      }
    },
    "./client": {
      "types": "./dist/auth-client.d.ts",
      "import": "./dist/auth-client.js",
      "require": "./dist/auth-client.cjs"
    },
    "./permissions": {
      "types": "./dist/permissions/platform.d.ts",
      "import": "./dist/permissions/platform.js",
      "require": "./dist/permissions/platform.cjs"
    },
    "./permissions/organization": {
      "types": "./dist/permissions/organization.d.ts",
      "import": "./dist/permissions/organization.js",
      "require": "./dist/permissions/organization.cjs"
    },
    "./types": {
      "types": "./dist/types/auth.d.ts",
      "import": "./dist/types/auth.js",
      "require": "./dist/types/auth.cjs"
    },
    "./types/organization": {
      "types": "./dist/types/organization.d.ts",
      "import": "./dist/types/organization.js",
      "require": "./dist/types/organization.cjs"
    },
    "./mobile": {
      "types": "./dist/adapters/mobile/expo-client.d.ts",
      "import": "./dist/adapters/mobile/expo-client.js",
      "require": "./dist/adapters/mobile/expo-client.cjs"
    },
    "./nestjs": {
      "types": "./dist/adapters/nestjs/index.d.ts",
      "import": "./dist/adapters/nestjs/index.js",
      "require": "./dist/adapters/nestjs/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/passkey": "catalog:",
    "@tanstack/react-query": "^5.101.1",
    "@workspace/config": "workspace:*",
    "@workspace/contracts": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "better-auth": "catalog:",
    "jose": "^6.1.3",
    "mongodb": "^7.2.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "expo-secure-store": ">=14.0.0",
    "hono": ">=4.0.0",
    "next": ">=15.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "auth": "catalog:",
    "@types/react": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
