{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./access-control": {
      "types": "./dist/access-control/index.d.ts",
      "import": "./dist/access-control/index.js",
      "require": "./dist/access-control/index.cjs"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./expo-client": {
      "types": "./src/client/expo-client.ts",
      "default": "./src/client/expo-client.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth-ui/react": "^1.6.15",
    "@better-auth/expo": "^1.6.14",
    "@workspace/config": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/utils": "workspace:*",
    "better-auth": "^1.6.14",
    "jose": "^6.1.0",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-config": "workspace:*",
    "eslint": "^9.17.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  }
}
