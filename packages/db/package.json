{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "MongoDB connection layer for theo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/config": "workspace:*",
    "@workspace/logger": "workspace:*",
    "mongoose": "^9.6.2"
  },
  "peerDependencies": {
    "mongodb": "~7.2"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "mongodb": "~7.2",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
