# Database
MONGODB_URI=mongodb://localhost:27017/theo

# Server
PORT=4000
APP_NAME=Theo
NODE_ENV=development

# Auth (served from apps/api)
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
AUTH_JWT_EXPIRATION=15m
AUTH_TOTP_ISSUER=Theo

# App URLs
CLIENT_URL=http://localhost:5173
MARKETING_URL=http://localhost:3000

# Client-side (set per app at build time)
VITE_API_URL=http://localhost:4000
VITE_AUTH_URL=http://localhost:4000
VITE_APP_NAME=Theo
VITE_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Theo
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_AUTH_URL=http://localhost:4000
EXPO_PUBLIC_APP_NAME=Theo

# Email
RESEND_API_KEY=
# EMAIL_FROM=Theo <no-reply@yourdomain.com>

# Storage (apps/api — when wired)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=http://localhost:4000/uploads

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
