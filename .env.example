# Database
MONGODB_URI=mongodb://localhost:27017/theo

# Server
PORT=4000
APP_NAME=Theo
NODE_ENV=development

# Auth (served from apps/api)
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8081
AUTH_TOTP_ISSUER=Theo
# Comma-separated user IDs with admin access before first role assignment (optional)
ADMIN_USER_IDS=

# App URLs
CLIENT_URL=http://localhost:5173
MARKETING_URL=http://localhost:3000

# Marketing (optional)
# GITHUB_REPO_URL=https://github.com/your-org/your-repo

# Client-side (set per app at build time)
# In Vite dev, leave URLs unset — the web dev server proxies /api and /v1 to the API.
# Set VITE_DEV_PROXY=false to call http://localhost:4000 directly (requires ALLOWED_ORIGINS).
VITE_API_URL=
VITE_AUTH_URL=
VITE_APP_NAME=Theo
VITE_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Theo
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_AUTH_URL=http://localhost:4000
EXPO_PUBLIC_CLIENT_URL=http://localhost:5173
EXPO_PUBLIC_APP_NAME=Theo

# Email
RESEND_API_KEY=
# EMAIL_FROM=Theo <no-reply@yourdomain.com>

# Storage (apps/api — when wired)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=http://localhost:4000/uploads
# Optional; defaults to BETTER_AUTH_SECRET for HMAC-signed local downloads
# STORAGE_SIGNING_SECRET=

# API rate limiting (/v1/* — auth routes use Better Auth limits)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Background jobs (apps/api — inline = in-process, redis = BullMQ)
JOBS_PROVIDER=inline
REDIS_URL=redis://localhost:6379
JOBS_QUEUE_NAME=theo

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Observability (optional — production only; leave blank to disable)
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=api
# VITE_SENTRY_DSN=
